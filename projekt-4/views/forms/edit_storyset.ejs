<form action="/edit/<%= storyset.slug %>" method="POST">
  <div>
    <label for="storyset_name">Nazwa zestawu</label>
    <input
      type="text"
      name="name"
      id="storyset_name"
      required
      minlength="3"
      maxlength="100"
      <% if (locals.storyset.name){ %>
      value="<%= storyset.name %>"
      <% }%>
    />
  </div>
  <input type="hidden" name="csrf_token" id="form_csrf_token" value="<%-session.csrf_token%>">
  <div>
    <button>Zapisz</button>
  </div>
</form>
