<%- include("head.partial.ejs") %>
<main>
  
  <h1><%= title %></h1>
  <div>
    <% if (locals.errors != null) {%>
    <ul id="errors">
      <% errors.forEach(function(error){ %>
      <li><%= error %></li>
      <% }) %>
    </ul>
    <% } %>
    <%- include("forms/edit_category.ejs") %>
    <% if (locals.category.stories && locals.category.stories.length > 0) { %>
      <ul id="stories">
        <% category.stories.forEach(function(story){ %>
        <li>
          <%- include("forms/edit_story.ejs", {story, category}) %>
          <form class="story-action" action="/delete/<%= category.id %>/<%= story.id %>" method="POST">
            <button>Usuń</button>
          </form>
        </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p>W tej kategorii nie ma żadnych historyjek. Dodaj nowe poniżej.</p>
    <% } %>
  </div>
  <a href="/view/<%= category.id %>">Powrót</a>
</main>

<%- include("foot.partial.ejs") %>
